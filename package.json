{
  "name": "sancheck",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:py": "PYTHONPATH=src python3 -m unittest discover -s tests",
    "check": "npm run build && PYTHONPATH=src python3 -m unittest discover -s tests && PYTHONPATH=src python3 -m compileall -q src tests"
  },
  "dependencies": {
    "@heroui/react": "latest",
    "@heroui/styles": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@tailwindcss/vite": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
